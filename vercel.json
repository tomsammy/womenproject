{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "!(api|node_modules|local-server.js)/**/*", "use": "@vercel/static" },
    { "src": "*", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/staffing", "destination": "/staffing.html" },
    { "source": "/api/config", "destination": "/api/config.js" },
    { "source": "/api/apply", "destination": "/api/apply.js" },
    { "source": "/api/donations", "destination": "/api/donations.js" },
    { "source": "/api/admin/applicants", "destination": "/api/admin/applicants.js" },
    { "source": "/api/admin/donations", "destination": "/api/admin/donations.js" }
  ]
}
